\subsection{Model Specification}{

\strong{Hierarchical model (Stage 2):}
\deqn{\theta_g \mid \mu, \tau \sim \text{Normal}(\mu, \tau^2), \quad g = 1, \ldots, G}
\deqn{\mu \sim \pi(\mu)}
\deqn{\tau \sim \pi(\tau)}

\strong{Stage 1 likelihood (Gaussian mixture approximation):}
\deqn{\theta_g \mid D_g \sim q_g(\theta_g) \approx \sum_{k=1}^K w_k \, \text{MVN}(\mu_k, \Sigma_k)}

\strong{Full posterior:}
\deqn{\pi(\theta, \mu, \tau \mid D) \propto 
  \left[\prod_{g=1}^G q_g(\theta_g)\right] 
  \left[\prod_{g=1}^G \text{Normal}(\theta_g \mid \mu, \tau^2)\right] 
  \pi(\mu) \pi(\tau)}

where \eqn{q_g(\theta_g)} approximates the Stage 1 posterior for group \eqn{g}.
}

\subsection{What's Fixed vs. Flexible}{

\strong{Fixed:}
\itemize{
\item Hierarchical distribution: \eqn{\theta_g \mid \mu, \tau \sim \text{Normal}(\mu, \tau^2)}
}

\strong{Flexible:}
\itemize{
\item Hyperpriors \eqn{\pi(\mu)} and \eqn{\pi(\tau)}: Normal, Student-t, Cauchy,
Lognormal, Gamma, Inverse-Gamma, Exponential, Uniform, mixtures (including
spike-and-slab), and truncated versions
\item Stage 1 posteriors: Can be non-Normal (handled by mixture approximation)
}
}

\subsection{Critical Requirements}{
\enumerate{
\item \strong{Stage 1 must use flat/uninformative priors} on \eqn{\theta_g}
\itemize{
\item Ensures two-stage = one-stage hierarchical model
\item Stan: Don't specify prior (defaults to flat)
\item JAGS/NIMBLE: Use very wide priors
}
\item \strong{Verify mixture quality:} \code{plot(mixture, draws = samples)}
\itemize{
\item Check density overlays and QQ plots
\item Poor approximation → biased shrinkage
}
\item \strong{Check prior implications:} \code{sample_prior_predictive(hierarchical_priors)}
\itemize{
\item Understand what priors imply before fitting
\item Avoid prior-data conflicts
}
\item \strong{Minimum 2 groups required} for heterogeneity estimation
}
}

\subsection{Common Prior Choices for τ}{

\itemize{
\item Half-Normal: \code{dist_truncated(dist_normal(0, s), lower = 0)} - Weakly informative
\item Half-t: \code{dist_truncated(dist_student_t(df, 0, s), lower = 0)} - Heavier tails
\item Half-Cauchy: \code{dist_truncated(dist_cauchy(0, s), lower = 0)} - Very diffuse
\item Uniform: \code{dist_uniform(0, U)} - Bounded heterogeneity
\item Inverse-Gamma: \code{dist_inverse_gamma(a, b)} - Traditional choice
}

